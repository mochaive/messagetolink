# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# logs
*.log

# claude code
.claude/settings.local.json

# claude skills & agents (local tooling, not project code)
.agents/
.claude/skills/
skills-lock.json

# oh-my-claudecode
.omc/

# interface design system (internal)
.interface-design/

# launch drafts (not for public)
docs/launch/

# playwright
.playwright-mcp/

# python cache
__pycache__/
*.pyc
